{
  "name": "agentforce-crm",
  "private": true,
  "version": "1.0.0",
  "description": "AgentForce CRM Salesforce Application",
  "scripts": {
    "lint": "eslint **/{aura,lwc}/**/*.js --no-error-on-unmatched-pattern",
    "test": "npm run test:unit",
    "test:unit": "sfdx-lwc-jest",
    "test:unit:watch": "sfdx-lwc-jest --watch",
    "test:unit:debug": "sfdx-lwc-jest --debug",
    "test:unit:coverage": "sfdx-lwc-jest --coverage",
    "test:workflow": "bash scripts/test-workflow-locally.sh",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "prettier:verify": "prettier --check \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "postinstall": "husky install",
    "precommit": "lint-staged",
    "cci:dev": "cci flow run dev_org --org dev",
    "cci:dev:full": "cci flow run feature_org --org dev",
    "cci:qa": "cci flow run qa_org --org qa",
    "cci:qa:full": "cci flow run qa_setup --org qa",
    "cci:feature": "cci flow run ci_feature --org feature",
    "cci:ci": "cci flow run ci_feature_test --org feature",
    "cci:beta": "cci flow run dev_org --org beta",
    "cci:release": "cci flow run dev_org --org release",
    "cci:org:create:dev": "cci org scratch dev dev",
    "cci:org:create:qa": "cci org scratch qa qa",
    "cci:org:create:feature": "cci org scratch feature feature",
    "cci:org:create:beta": "cci org scratch beta beta",
    "cci:org:create:release": "cci org scratch release release",
    "cci:org:info": "cci org info dev",
    "cci:org:info:qa": "cci org info qa",
    "cci:org:info:beta": "cci org info beta",
    "cci:org:info:release": "cci org info release",
    "cci:org:open": "cci org browser dev",
    "cci:org:open:qa": "cci org browser qa",
    "cci:org:open:beta": "cci org browser beta",
    "cci:org:open:release": "cci org browser release",
    "cci:org:delete": "cci org scratch_delete dev",
    "cci:org:delete:qa": "cci org scratch_delete qa",
    "cci:org:delete:beta": "cci org scratch_delete beta",
    "cci:org:delete:release": "cci org scratch_delete release",
    "cci:org:list": "cci org list",
    "cci:test:apex": "cci task run run_tests --org dev",
    "cci:test:robot": "cci task run robot --org dev"
  },
  "devDependencies": {
    "@lwc/eslint-plugin-lwc": "^2.0.0",
    "@prettier/plugin-xml": "^3.2.2",
    "@salesforce/eslint-config-lwc": "^3.2.3",
    "@salesforce/eslint-plugin-aura": "^2.0.0",
    "@salesforce/eslint-plugin-lightning": "^1.0.0",
    "@salesforce/sfdx-lwc-jest": "^7.0.1",
    "eslint": "8.57.1",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jest": "^28.8.1",
    "husky": "^9.1.5",
    "lint-staged": "^15.1.0",
    "prettier": "^3.1.0",
    "prettier-plugin-apex": "^2.0.1"
  },
  "lint-staged": {
    "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
      "prettier --write"
    ],
    "**/{aura,lwc}/**/*.js": [
      "eslint"
    ]
  }
}
